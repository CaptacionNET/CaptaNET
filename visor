<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>CaptaNET – Visor</title>

<!-- Tabulator -->
<link href="https://unpkg.com/tabulator-tables@5.6.1/dist/css/tabulator.min.css" rel="stylesheet">
<script src="https://unpkg.com/tabulator-tables@5.6.1/dist/js/tabulator.min.js"></script>

<!-- Supabase -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<style>
body { font-family: Arial; margin: 0; padding: 0; }
#topbar { display:flex; gap:10px; padding:10px; background:#eee; }
button { padding:8px 14px; cursor:pointer; }
#filtros { padding:10px; background:#f7f7f7; display:flex; gap:10px; }
#tabla { margin:10px; }
.modal {
  display:none; position:fixed; top:0; left:0; width:100%; height:100%;
  background:rgba(0,0,0,0.5); justify-content:center; align-items:center;
}
.modal-content {
  background:white; padding:20px; width:400px; border-radius:6px;
}
</style>
</head>

<body>

<div id="topbar">
  <button onclick="modoCompeticiones()">Competiciones</button>
  <button onclick="modoValoraciones()">Valoraciones</button>
  <button onclick="modoBuscador()">Buscador</button>
</div>

<div id="filtros"></div>

<div id="tabla"></div>

<!-- Modal comentario -->
<div id="modalComentario" class="modal">
  <div class="modal-content">
    <h3>Comentario</h3>
    <textarea id="comentarioInput" style="width:100%;height:120px;"></textarea>
    <br><br>
    <button onclick="guardarComentario()">Guardar</button>
    <button onclick="cerrarModal()">Cerrar</button>
  </div>
</div>

<script>
/* ============================
   CONFIG SUPABASE
============================ */
const supabase = supabase.createClient(
  "TU_URL_SUPABASE",
  "TU_PUBLIC_ANON_KEY"
);

const USER_CLUB_ID = window.USER_CLUB_ID || "CLUB_ID_DEL_USUARIO";

/* ============================
   TABLA PRINCIPAL
============================ */
let tabla;
let filaComentario = null;

function crearTabla() {
  tabla = new Tabulator("#tabla", {
    layout:"fitColumns",
    height:"80vh",
    columns:[
      {title:"Jugador", field:"jugador_nombre"},
      {title:"Año", field:"anio_nacimiento", editor:"number"},
      {title:"Posición", field:"posicion", editor:"input"},
      {title:"Valoración", field:"valoracion", editor:"number"},
      {title:"Contacto", field:"contacto", editor:"input"},
      {title:"Contactado", field:"contactado", editor:"tickCross"},
      {
        title:"Comentario",
        field:"comentario",
        formatter:"button",
        formatterParams:{label:"Ver"},
        width:120,
        cellClick:function(e, cell){
          filaComentario = cell.getRow().getData();
          document.getElementById("comentarioInput").value = filaComentario.comentario || "";
          abrirModal();
        }
      }
    ],
    cellEdited: async function(cell){
      const d = cell.getRow().getData();
      await supabase.from("jugadores_club")
        .update({ [cell.getField()]: cell.getValue() })
        .eq("id", d.id);
    }
  });
}
crearTabla();

/* ============================
   MODAL COMENTARIO
============================ */
function abrirModal(){ document.getElementById("modalComentario").style.display="flex"; }
function cerrarModal(){ document.getElementById("modalComentario").style.display="none"; }

async function guardarComentario(){
  const nuevo = document.getElementById("comentarioInput").value;
  await supabase.from("jugadores_club")
    .update({ comentario:nuevo })
    .eq("id", filaComentario.id);

  filaComentario.comentario = nuevo;
  tabla.updateData([filaComentario]);
  cerrarModal();
}

/* ============================
   MODO: COMPETICIONES
============================ */
async function modoCompeticiones(){
  document.getElementById("filtros").innerHTML = `
    <select id="fCat"></select>
    <select id="fLiga"></select>
    <select id="fGrupo"></select>
    <select id="fEquipo"></select>
  `;

  cargarCategorias();

  document.getElementById("fCat").onchange = cargarLigas;
  document.getElementById("fLiga").onchange = cargarGrupos;
  document.getElementById("fGrupo").onchange = cargarEquipos;
  document.getElementById("fEquipo").onchange = cargarJugadoresEquipo;
}

async function cargarCategorias(){
  const {data} = await supabase.from("categorias").select("*");
  fillSelect("fCat", data);
}
async function cargarLigas(){
  const cat = document.getElementById("fCat").value;
  const {data} = await supabase.from("ligas").select("*").eq("categoria_id", cat);
  fillSelect("fLiga", data);
}
async function cargarGrupos(){
  const liga = document.getElementById("fLiga").value;
  const {data} = await supabase.from("grupos").select("*").eq("liga_id", liga);
  fillSelect("fGrupo", data);
}
async function cargarEquipos(){
  const grupo = document.getElementById("fGrupo").value;
  const {data} = await supabase.from("equipos").select("*").eq("grupo_id", grupo);
  fillSelect("fEquipo", data);
}
async function cargarJugadoresEquipo(){
  const equipo = document.getElementById("fEquipo").value;

  const {data} = await supabase
    .from("jugadores_club")
    .select("*, jugadores(nombre, apellido)")
    .eq("club_id", USER_CLUB_ID)
    .eq("jugadores.equipo_id", equipo);

  const rows = data.map(r => ({
    ...r,
    jugador_nombre: r.jugadores.nombre + " " + r.jugadores.apellido
  }));

  tabla.setData(rows);
}

/* ============================
   MODO: VALORACIONES
============================ */
function modoValoraciones(){
  document.getElementById("filtros").innerHTML = `
    Valoración mínima:
    <input id="fVal" type="number" value="1">
    Año nacimiento:
    <input id="fAnio" type="number">
    <button onclick="filtrarValoraciones()">Filtrar</button>
  `;
}

async function filtrarValoraciones(){
  const val = document.getElementById("fVal").value;
  const anio = document.getElementById("fAnio").value;

  let q = supabase
    .from("jugadores_club")
    .select("*, jugadores(nombre, apellido), equipos(nombre)")
    .eq("club_id", USER_CLUB_ID)
    .gte("valoracion", val);

  if(anio) q = q.eq("anio_nacimiento", anio);

  const {data} = await q;

  const rows = data.map(r => ({
    ...r,
    jugador_nombre: r.jugadores.nombre + " " + r.jugadores.apellido
  }));

  tabla.setData(rows);
}

/* ============================
   MODO: BUSCADOR
============================ */
function modoBuscador(){
  document.getElementById("filtros").innerHTML = `
    <input id="fTexto" placeholder="Nombre jugador">
    <button onclick="buscarJugador()">Buscar</button>
  `;
}

async function buscarJugador(){
  const texto = document.getElementById("fTexto").value;

  const {data} = await supabase
    .from("jugadores_club")
    .select("*, jugadores(nombre, apellido)")
    .eq("club_id", USER_CLUB_ID)
    .ilike("jugadores.nombre", "%" + texto + "%");

  const rows = data.map(r => ({
    ...r,
    jugador_nombre: r.jugadores.nombre + " " + r.jugadores.apellido
  }));

  tabla.setData(rows);
}

/* ============================
   UTILIDAD
============================ */
function fillSelect(id, arr){
  const s = document.getElementById(id);
  s.innerHTML = "";
  arr.forEach(x => {
    const o = document.createElement("option");
    o.value = x.id;
    o.textContent = x.nombre;
    s.appendChild(o);
  });
}
</script>

</body>
</html>
